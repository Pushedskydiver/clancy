{
  "name": "chief-clancy",
  "version": "0.3.0",
  "description": "Autonomous, board-driven development for Claude Code — scaffolds docs, integrates Kanban boards, runs tickets in a loop.",
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "kanban",
    "jira",
    "github-issues",
    "linear",
    "autonomous",
    "slash-commands"
  ],
  "homepage": "https://github.com/Pushedskydiver/clancy#readme",
  "bugs": {
    "url": "https://github.com/Pushedskydiver/clancy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pushedskydiver/clancy.git"
  },
  "license": "MIT",
  "author": "Alex Clapperton",
  "type": "module",
  "bin": {
    "clancy": "dist/installer/install.js"
  },
  "main": "dist/installer/install.js",
  "exports": {
    "./scripts/once": "./dist/scripts/once/once.js",
    "./scripts/afk": "./dist/scripts/afk/afk.js"
  },
  "files": [
    "dist/",
    "hooks/",
    "src/commands/",
    "src/workflows/",
    "src/agents/",
    "src/templates/",
    "registry/"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "vitest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
