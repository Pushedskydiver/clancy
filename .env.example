# Clancy contributor .env — for running test/smoke/smoke.sh
# Copy to .env and fill in the board(s) you want to smoke test.
# Leave other sections blank — the smoke test skips boards with no credentials.

# ─── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER=you@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ

# ─── GitHub Issues ────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# ─── Linear ───────────────────────────────────────────────────────────────────
# Note: personal API keys do NOT use a Bearer prefix — this is correct.
LINEAR_API_KEY=
LINEAR_TEAM_ID=
